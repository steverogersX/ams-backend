# Server
NODE_ENV=development
PORT=3000

# CORS (comma-separated list of allowed origins, or * for all)
CORS_ORIGIN=*

# Database (PostgreSQL connection string)
DATABASE_URL=postgres://user:pass@localhost:5432/ams

# Auth
SESSION_EXPIRES_IN_DAYS=30

# Logging (optional: fatal|error|warn|info|debug|trace|silent)
# Defaults to "info" in production and "debug" otherwise.
# LOG_LEVEL=info
